        "type": "object",
        "properties": {
          "amount": {
            "type": "number",
            "description": "USD amount to invest"
          },
          "risk": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ],
            "description": "Risk tolerance"
          },
          "duration": {
            "type": "integer",
            "description": "Investment duration in days. Default 30."
          },
          "chain": {
            "type": "string",
            "description": "Optional chain filter (e.g., 'base')"
          },
          "stables": {
            "type": "boolean",
            "description": "Stablecoins-only filter. Default false (true for low risk)."
          }
        },
        "required": [
          "amount",
          "risk"
        ]
      },
      "annotations": {
        "title": "DeFi Yield Recommendation",
        "readOnlyHint": true,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": true
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number"
          },
          "risk": {
            "type": "string"
          },
          "duration": {
            "type": "integer"
          },
          "top": {
            "type": "array",
            "description": "Top yield picks ranked by APY",
            "items": {
              "type": "object",
              "properties": {
                "project": {
                  "type": "string"
                },
                "chain": {
                  "type": "string"
                },
                "symbol": {
                  "type": "string"
                },
                "apy": {
                  "type": "number"
                },
                "tvlUsd": {
                  "type": "number"
                },
                "projectedYieldUsd": {
                  "type": "number"
                }
              }
            }
          }
        }
      }
    },
    {
      "name": "hyperd.token.info",

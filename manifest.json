    {
      "name": "hyperd.balance.get",
      "description": "Get the on-chain balance for an EVM wallet address. Multi-chain (Base, Ethereum, Polygon, Arbitrum). Supports ERC-20 by symbol or contract address. Pass chain='all' for parallel multi-chain lookup. Costs $0.01 in USDC on Base.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "address": {
            "type": "string",
            "description": "0x EVM wallet address"
          },
          "token": {
            "type": "string",
            "description": "Token symbol (e.g., USDC, WETH) or contract address. Default USDC."
          },
          "chain": {
            "type": "string",
            "enum": [
              "base",
              "ethereum",
              "polygon",
              "arbitrum",
              "base-sepolia",
              "all",
              "optimism",
              "avalanche",
              "bnb"
            ],
            "description": "Chain. Default 'base'. Use 'all' for parallel multi-chain."
          }
        },
        "required": [
          "address"
        ]
      },
      "annotations": {
        "title": "Wallet Balance",
        "readOnlyHint": true,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": true
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "address": {
            "type": "string"
          },
          "chain": {
            "type": "string"
          },
          "token": {
            "type": "string"
          },
          "symbol": {
            "type": "string"
          },
          "balance": {
            "type": "string",
            "description": "Balance as a decimal string"
          },
          "raw": {
            "type": "string",
            "description": "Raw balance in smallest units"
          },
          "decimals": {
            "type": "integer"
          }
        }
      }
    },
    {
      "name": "hyperd.yield.recommend",
      "description": "Get an opinionated DeFi yield recommendation. Filters DefiLlama's pool universe by risk tier (low/medium/high), TVL, and IL exposure, then ranks by APY. Returns the top picks plus projected $ yield over your duration. Costs $0.05 in USDC.",

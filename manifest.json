        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["liquidation"], "description": "Watch type. v1.0 only supports 'liquidation'." },
          "target_addresses": {
            "type": "array",
            "minItems": 1,
            "maxItems": 1,
            "items": { "type": "string" },
            "description": "Wallet to watch (length-1 in v1.0; multi-target reserved for v1.1 Pro tier)."
          },
          "target_chain": {
            "type": "string",
            "enum": ["base", "ethereum", "polygon", "arbitrum", "optimism", "avalanche", "bnb"],
            "description": "Chain to watch. Default 'base'."
          },
          "webhook_url": { "type": "string", "description": "HTTPS endpoint to POST alerts to. Must be publicly reachable; private/loopback IPs rejected." },
          "fire_on_band_or_worse": {
            "type": "string",
            "enum": ["safe", "caution", "warning", "critical"],
            "description": "Fire when health-factor band reaches this severity OR worse. Default 'warning'."
